# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# ── General ───────────────────────────────────────────────────────────
# Nombre del bot mostrado en la interfaz
BOT_NAME=PIBot
# Modo debug de la aplicacion (true/false)
DEBUG=false
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── BDE (Base de Datos Estadisticos - Banco Central) ─────────────────
# Timeout en segundos para las llamadas a la API del BDE
BDE_TIMEOUT_SEC=15
# Credenciales de acceso a la API REST del Banco Central
# Solicitar en: https://si3.bcentral.cl/Siete/es/Siete/API
BDE_USER=tu_email@ejemplo.com
BDE_PASS=tu_password
BDE_BASE_URL=https://si3.bcentral.cl/SieteRestWS/SieteRestWS.ashx

# ── BCCH (compatibilidad legacy, usado por get_data_serie) ───────────
BCCH_USER=tu_email@ejemplo.com
BCCH_PASS=tu_password

# ── RAG ───────────────────────────────────────────────────────────────
# Habilitar/deshabilitar modulo RAG (true/false)
RAG_ENABLED=true
# Backend de RAG: pgvector
RAG_BACKEND=pgvector
# Nombre de la coleccion de PGVector para RAG
RAG_PGVECTOR_COLLECTION=methodology

# ── PostgreSQL ────────────────────────────────────────────────────────
# Connection string de PostgreSQL (memoria, RAG, intent store)
PG_DSN=postgresql://postgres:postgres@localhost:5432/pibot

# ── Redis ─────────────────────────────────────────────────────────────
# Password de Redis (usada en docker-compose para levantar el servicio)
REDIS_PASS=tu_redis_password
# URL de conexion a Redis (incluye credenciales)
REDIS_URL=redis://default:tu_redis_password@localhost:6379/0
# Activar cache Redis para llamadas a la API del BDE (true/false)
USE_REDIS_CACHE=true

# ── Logging y memoria ────────────────────────────────────────────────
# Archivo de log opcional para el proceso principal (vacio = desactivado)
RUN_MAIN_LOG=run_main.log
# Si es true/1, la app falla si no puede conectar a PostgreSQL para memoria
REQUIRE_PG_MEMORY=true

# ── Clasificador / NLU ───────────────────────────────────────────────
# URL del servicio de prediccion JointBERT
PREDICT_URL=http://localhost:8000/predict

# ── Ingesta ───────────────────────────────────────────────────────────
# Ejecutar ingesta de series al iniciar la app (0=no, 1=si)
INGEST_ON_START=0
